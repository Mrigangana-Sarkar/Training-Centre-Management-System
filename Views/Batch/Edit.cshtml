@model TrainingCentreManagementSystem.Models.Batch

<h2>Edit Batch</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="BatchId" />

    <div>
        <label>Batch Name</label>
        <input asp-for="BatchName" class="form-control" />
    </div>

    <div>
        <label>Course</label>

        <select asp-for="CourseId" class="form-control">

            @foreach (var course in ViewBag.Courses)
            {
                <option value="@course.CourseId">@course.CourseName</option>
            }

        </select>

    </div>

    <div>
        <label>Trainer</label>

        <select asp-for="TrainerId" class="form-control">

            @foreach (var trainer in ViewBag.Trainers)
            {
                <option value="@trainer.TrainerId">@trainer.TrainerName</option>
            }

        </select>

    </div>

    <div>
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div>
        <label>End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <br>

    <button type="submit" class="btn btn-success">Update</button>

</form>