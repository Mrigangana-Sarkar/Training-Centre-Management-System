@model TrainingCentreManagementSystem.Models.Attendance

<h2>Edit Attendance</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="AttendanceId" />

    <div>
        <label>Student</label>

        <select asp-for="StudentId" class="form-control">

            @foreach (var student in ViewBag.Students)
            {
                <option value="@student.StudentId">@student.StudentName</option>
            }

        </select>

    </div>

    <div>
        <label>Batch</label>

        <select asp-for="BatchId" class="form-control">

            @foreach (var batch in ViewBag.Batches)
            {
                <option value="@batch.BatchId">@batch.BatchName</option>
            }

        </select>

    </div>

    <div>
        <label>Date</label>
        <input asp-for="Date" type="date" class="form-control" />
    </div>

    <div>
        <label>Status</label>

        <select asp-for="Status" class="form-control">
            <option>Present</option>
            <option>Absent</option>
        </select>

    </div>

    <br>

    <button type="submit" class="btn btn-success">Update</button>

</form>
