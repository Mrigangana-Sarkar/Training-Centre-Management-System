@{
    ViewData["Title"] = "Student Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<h2 class="text-center mt-3 mb-4">Student Dashboard</h2>

<div class="container">

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card text-white bg-success shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Courses</h5>
                    <p>View your enrolled courses</p>
                    <a href="/Course" class="btn btn-light">View Courses</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-primary shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Batch</h5>
                    <p>View your assigned batch</p>
                    <a href="/Batch" class="btn btn-light">View Batch</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-dark shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Training Schedule</h5>
                    <p>Check your training schedule</p>
                    <a href="/Schedule" class="btn btn-light">View Schedule</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-danger shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Attendance</h5>
                    <p>View your attendance records</p>
                    <a href="/Attendance" class="btn btn-light">View Attendance</a>
                </div>
            </div>
        </div>

    </div>

    <br>

    <div class="text-center">
        <a href="/Account/Logout" class="btn btn-outline-danger btn-lg">Logout</a>
    </div>

</div>